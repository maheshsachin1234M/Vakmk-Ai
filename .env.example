# ============================================
# VAKMK AI — Root Environment Variables
# Copy to .env and fill with real values
# ============================================

# --- Project ---
PROJECT_NAME=VAKMK AI
ENVIRONMENT=development

# --- Database (PostgreSQL) ---
POSTGRES_USER=vakmk
POSTGRES_PASSWORD=vakmk_secure_password_change_me
POSTGRES_DB=vakmk_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Vector DB ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=vakmk_documents

# --- File Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=VAKMK AI
