# ============================================
# VAKMK AI — .gitignore
# ============================================

# ---------- OS ----------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---------- Editors ----------
.vscode/
.idea/
*.iml
.cursor/

# ---------- Environment & Secrets ----------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# ---------- Python (Backend) ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/
.virtualenv/

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ---------- Node / Next.js (Frontend) ----------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js
.next/
out/
build/
.swc/

# Testing
coverage/

# Production
*.tsbuildinfo
next-env.d.ts

# Misc
.npm
.eslintcache
.turbo
.vercel

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Project specific ----------
backend/uploads/*
!backend/uploads/.gitkeep

backend/chroma_db/*
!backend/chroma_db/.gitkeep

backend/*.db
backend/*.sqlite
backend/*.sqlite3

# Docker
docker-compose.override.yml
