# =====================================================
# VAKMK AI — Backend environment variables
# Copy to backend/.env and fill in your values
# =====================================================

# --- App ---
PROJECT_NAME=VAKMK AI
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database ---
# For Docker compose use POSTGRES_HOST=postgres
# For local dev use POSTGRES_HOST=localhost
POSTGRES_USER=vakmk
POSTGRES_PASSWORD=vakmk_secure_password_change_me
POSTGRES_DB=vakmk_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Alternative: use full DATABASE_URL (overrides individual vars)
# DATABASE_URL=postgresql://vakmk:password@localhost:5432/vakmk_ai

# Quick start without Postgres? Use SQLite:
# DATABASE_URL=sqlite:///./vakmk.db

# --- Auth ---
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- RAG / Vector store ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=vakmk_documents
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25
